# Endpoints for implements interfaces
Endpoints.Lidar3D = "tcp -p 11990"
Endpoints.MediaPlaneDDS = "tcp -p 11890"

# Proxies for required interfaces
Proxies.Lidar3D = "lidar3d:tcp -h localhost -p 11988"

# Robot-body self-filter (Embree). Removes lidar points hitting the static robot mesh.
MeshFilter.enabled = true
Robot.name = "Shadow"
Floor.z = 110.0
Top.z = 2100.0
Dilate = 0.05
# Robot-frame footprint disc: drops base/wheels/arm returns the STL doesn't model.
# radius in metres, z-band in mm. radius = 0 disables. Safe: inside the robot's own
# footprint nothing is a real obstacle.
Footprint.radius = 0.55
Footprint.z_min = 110.0
Footprint.z_max = 1350.0
# Wider near-floor skirt (low z-band): catches near-floor self/reflection returns past
# the body footprint without hiding upright obstacles (their returns above z_max stay).
Skirt.radius = 0.75
Skirt.z_min = 110.0
Skirt.z_max = 600.0

### Lidar params ###
# RSHELIOS=0   RSBPEARL=1
lidar_model = 0
dest_pc_ip_addr = "192.168.50.210"
msop_port = 6699
difop_port = 7788
simulator = true

# DDS lidar media plane (zero-copy LidarFrame). Metadata is advertised into DSR by
# the robot_concept agent, not here.
PublishDDS = true
DDS.Domain = 7
DDS.Topic = "rc/lidar3d/points"
DDS.HistoryDepth = 8
DDS.SharedMemoryOnly = true
DDS.DataSharing = false

#Warning use "." for decimals not ","
rx = -0.0
ry = 0.0
rz = 0.0
tx = 0.0
ty = -155.0
tz = 1030.0	 #970.0

Period.Compute = 50
Period.Emergency = 500

Ice.Warn.Connections = "0"
Ice.Trace.Network = "0"
Ice.Trace.Protocol = "0"
Ice.MessageSizeMax = "20004800"
Component.Debug.Verbose = true
